<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_white_rounded_top">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="#DDDDDD" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Garment Type"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="20dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:useDefaultMargins="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickShirt"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="Shirt"
            android:textColor="#D32F2F"
            app:strokeColor="#D32F2F"
            app:cornerRadius="12dp"
            app:icon="@drawable/frame"
            app:iconPadding="8dp"
            app:iconTint="#D32F2F"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickPant"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="Pant"
            android:textColor="#D32F2F"
            app:strokeColor="#D32F2F"
            app:cornerRadius="12dp"
            app:icon="@drawable/order"
            app:iconPadding="8dp"
            app:iconTint="#D32F2F"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickKoti"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="Koti"
            android:textColor="#D32F2F"
            app:strokeColor="#D32F2F"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickSuit"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="Suit"
            android:textColor="#D32F2F"
            app:strokeColor="#D32F2F"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickJabbho"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="Jabbho"
            android:textColor="#D32F2F"
            app:strokeColor="#D32F2F"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickLehngho"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="Lehngho"
            android:textColor="#D32F2F"
            app:strokeColor="#D32F2F"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickSafari"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="Safari"
            android:textColor="#D32F2F"
            app:strokeColor="#D32F2F"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickJodhpuri"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="Jodhpuri"
            android:textColor="#D32F2F"
            app:strokeColor="#D32F2F"
            app:cornerRadius="12dp" />

    </GridLayout>

</LinearLayout>
