<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- Top Red Header Area -->

    <!-- Shop Name & Notification -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@drawable/bg_header_rounded"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="0dp" />

    <ImageView
        android:id="@+id/ivShopLogo"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/dt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@android:color/white" />

    <TextView
        android:id="@+id/tvShopName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Dhandhukiya Tailor Shop"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/ivShopLogo"
        app:layout_constraintEnd_toStartOf="@id/ivNotification"
        app:layout_constraintStart_toEndOf="@id/ivShopLogo"
        app:layout_constraintTop_toTopOf="@id/ivShopLogo" />

    <ImageView
        android:id="@+id/ivNotification"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_circle_black"
        android:backgroundTint="#E57373"
        android:padding="8dp"
        android:src="@android:drawable/ic_popup_reminder"
        app:layout_constraintBottom_toBottomOf="@id/ivShopLogo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/ivShopLogo"
        app:tint="@android:color/white" />

    <!-- Search Bar (Floating) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/searchCard"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="@id/headerBackground"
        app:layout_constraintTop_toBottomOf="@id/headerBackground">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="12dp">

            <ImageView
                android:id="@+id/ivSearch"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_search"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#9CA3AF" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:hint="Search customers, orders, or fabrics"
                android:inputType="text"
                android:textSize="14sp"
                app:layout_constraintEnd_toStartOf="@id/ivFilter"
                app:layout_constraintStart_toEndOf="@id/ivSearch" />

            <ImageView
                android:id="@+id/ivFilter"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#D32F2F" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Dev Mode Switch (Placed under search for now) -->
    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchDevMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/searchCard"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Alphabet Bar -->
    <HorizontalScrollView
        android:id="@+id/svAlphabet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/searchCard">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAll"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="ALL"
                android:backgroundTint="#D32F2F"
                android:textColor="@android:color/white"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="20dp" />

            <!-- Dynamic Buttons A-Z -->
            <com.google.android.material.button.MaterialButton android:id="@+id/btnA" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginStart="8dp" android:text="A" android:textColor="#666666" app:strokeColor="#EEEEEE" app:cornerRadius="20dp" android:insetTop="0dp" android:insetBottom="0dp" android:padding="0dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnB" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginStart="8dp" android:text="B" android:textColor="#666666" app:strokeColor="#EEEEEE" app:cornerRadius="20dp" android:insetTop="0dp" android:insetBottom="0dp" android:padding="0dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnC" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginStart="8dp" android:text="C" android:textColor="#666666" app:strokeColor="#EEEEEE" app:cornerRadius="20dp" android:insetTop="0dp" android:insetBottom="0dp" android:padding="0dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnD" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginStart="8dp" android:text="D" android:textColor="#666666" app:strokeColor="#EEEEEE" app:cornerRadius="20dp" android:insetTop="0dp" android:insetBottom="0dp" android:padding="0dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnE" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginStart="8dp" android:text="E" android:textColor="#666666" app:strokeColor="#EEEEEE" app:cornerRadius="20dp" android:insetTop="0dp" android:insetBottom="0dp" android:padding="0dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnF" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginStart="8dp" android:text="F" android:textColor="#666666" app:strokeColor="#EEEEEE" app:cornerRadius="20dp" android:insetTop="0dp" android:insetBottom="0dp" android:padding="0dp"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Recent Customers Title -->
    <TextView
        android:id="@+id/tvCustomerListTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:text="Recent Customers"
        android:textColor="@android:color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/svAlphabet" />

    <TextView
        android:id="@+id/tvViewAll"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:text="View All →"
        android:textColor="#D32F2F"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/tvCustomerListTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvCustomerListTitle" />

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCustomers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCustomerListTitle"
        tools:listitem="@layout/item_customer" />

    <!-- Navigation Bar -->
    <include
        android:id="@+id/bottomNavigation"
        layout="@layout/reusable_bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
